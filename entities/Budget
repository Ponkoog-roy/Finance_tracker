{
  "name": "Budget",
  "type": "object",
  "properties": {
    "category": {
      "type": "string",
      "description": "Budget category"
    },
    "amount": {
      "type": "number",
      "description": "Budget limit"
    },
    "spent": {
      "type": "number",
      "default": 0,
      "description": "Amount spent"
    },
    "month": {
      "type": "string",
      "description": "Budget month (YYYY-MM)"
    },
    "color": {
      "type": "string",
      "description": "Display color"
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "category",
    "amount",
    "month"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}